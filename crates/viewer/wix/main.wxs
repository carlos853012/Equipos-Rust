<?xml version='1.0' encoding='windows-1252'?>
<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='Equipos Industriales viewer'
        UpgradeCode='62EA49C9-39DA-4AFA-AB8F-289F10D9536E'
        Manufacturer='Carlos Donoso'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Manufacturer='Carlos Donoso'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'
        />

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='Equipos Industriales Viewer Installation'/>

        <Directory Id='TARGETDIR' Name='SourceDir'>
            
            <Directory Id='$(var.PlatformProgramFilesFolder)' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='Equipos Industriales Viewer'>
                    <Directory Id='Bin' Name='bin'>
                        <Component Id='Path' Guid='9ED55FAC-D827-4D6D-B5D6-CA29021382D3' KeyPath='yes'>
                            <Environment
                                Id='PATH'
                                Name='PATH'
                                Value='[Bin]'
                                Permanent='no'
                                Part='last'
                                Action='set'
                                System='yes'/>
                        </Component>
                        <Component Id='binary0' Guid='*'>
                            <File
                                Id='exe0'
                                Name='viewer.exe'
                                DiskId='1'
                                Source='$(var.CargoTargetBinDir)\viewer.exe'
                                KeyPath='yes'/>
                        </Component>
                    </Directory>
                </Directory>
            </Directory>

            <Directory Id='ProgramMenuFolder'>
                <Directory Id='ApplicationProgramsFolder' Name='Equipos Industriales'/>
            </Directory>

            <Directory Id='DesktopFolder' Name='Desktop'/>

        </Directory> 
        <Feature
            Id='Binaries'
            Title='Application'
            Description='Installs the viewer application and shortcuts.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>
            <ComponentRef Id='binary0'/>
            <ComponentRef Id='ShortcutStartMenu'/>
            <ComponentRef Id='ShortcutDesktop'/>

            <Feature
                Id='Environment'
                Title='PATH Environment Variable'
                Description='Add the install location of the [ProductName] executable to the PATH system environment variable. This allows the [ProductName] executable to be called from any location.'
                Level='1'
                Absent='allow'>
                <ComponentRef Id='Path'/>
            </Feature>
        </Feature>

        <SetProperty Id='ARPINSTALLLOCATION' Value='[APPLICATIONFOLDER]' After='CostFinalize'/>

        <DirectoryRef Id='ApplicationProgramsFolder'>
            <Component Id='ShortcutStartMenu' Guid='*'>
                <Shortcut Id='StartMenuShortcut'
                    Name='Equipos Industriales Viewer'
                    Description='Start the Equipos Industriales Viewer'
                    Target='[Bin]viewer.exe'
                    WorkingDirectory='Bin'/>
                <RemoveFolder Id='RemoveAppProgramsFolder' Directory='ApplicationProgramsFolder' On='uninstall'/>
                <RegistryValue Root='HKCU' Key='Software\EquiposIndustriales\Viewer' Name='installed' Type='integer' Value='1' KeyPath='yes'/>
            </Component>
        </DirectoryRef>

        <DirectoryRef Id='DesktopFolder'>
            <Component Id='ShortcutDesktop' Guid='*'>
                <Shortcut Id='DesktopShortcut'
                    Name='Equipos Industriales Viewer'
                    Description='Start the Equipos Industriales Viewer'
                    Target='[Bin]viewer.exe'
                    WorkingDirectory='Bin'/>
                <RemoveFolder Id='RemoveDesktopFolder' Directory='DesktopFolder' On='uninstall'/>
                <RegistryValue Root='HKCU' Key='Software\EquiposIndustriales\Viewer' Name='desktop' Type='integer' Value='1' KeyPath='yes'/>
            </Component>
        </DirectoryRef>

        <UI>
            <UIRef Id='WixUI_FeatureTree'/>
            <Publish Dialog='WelcomeDlg' Control='Next' Event='NewDialog' Value='CustomizeDlg' Order='99'>1</Publish>
            <Publish Dialog='CustomizeDlg' Control='Back' Event='NewDialog' Value='WelcomeDlg' Order='99'>1</Publish>
        </UI>

    </Product>
</Wix>