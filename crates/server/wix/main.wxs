<?xml version='1.0' encoding='windows-1252'?>
<?if $(sys.BUILDARCH) = x64 or $(sys.BUILDARCH) = arm64 ?>
    <?define PlatformProgramFilesFolder = "ProgramFiles64Folder" ?>
<?else ?>
    <?define PlatformProgramFilesFolder = "ProgramFilesFolder" ?>
<?endif ?>

<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>

    <Product
        Id='*'
        Name='Equipos Industriales Server'
        UpgradeCode='484F1962-9C9C-430D-8B2F-7A29D347AF4C'
        Manufacturer='Carlos Donoso'
        Language='1033'
        Codepage='1252'
        Version='$(var.Version)'>

        <Package Id='*'
            Keywords='Installer'
            Manufacturer='Carlos Donoso'
            InstallerVersion='450'
            Languages='1033'
            Compressed='yes'
            InstallScope='perMachine'
            SummaryCodepage='1252'/>

        <MajorUpgrade
            Schedule='afterInstallInitialize'
            DowngradeErrorMessage='A newer version of [ProductName] is already installed. Setup will now exit.'/>

        <Media Id='1' Cabinet='media1.cab' EmbedCab='yes' DiskPrompt='CD-ROM #1'/>
        <Property Id='DiskPrompt' Value='Equipos Industriales Server Installation'/>

        <Directory Id='TARGETDIR' Name='SourceDir'>
            <Directory Id='$(var.PlatformProgramFilesFolder)' Name='PFiles'>
                <Directory Id='APPLICATIONFOLDER' Name='EquiposIndustriales'>

                    <!-- Binario principal del server -->
                    <Directory Id='Bin' Name='bin'>
                        <Component Id='binary0' Guid='A1B2C3D4-E5F6-7890-ABCD-EF1234567890'>
                            <File Id='exe0' Name='server.exe' DiskId='1'
                                  Source='$(var.CargoTargetBinDir)\server.exe'
                                  KeyPath='yes'/>
                        </Component>
                    </Directory>

                    <!-- Binarios de PostgreSQL embebido -->
                    <Directory Id='TheseusPgDir' Name='.theseus'>
                        <Directory Id='TheseusPgPostgresql' Name='postgresql'>
                            <Directory Id='TheseusPgVersion' Name='18.3.0'>
                                <Directory Id='PgBinDir' Name='bin'>
                                    <Component Id='CmpInitdb' Guid='B0000001-0000-0000-0000-000000000001'>
                                        <File Id='FileInitdb' Name='initdb.exe' DiskId='1' KeyPath='yes' Source='C:\Users\carlos\.theseus\postgresql\18.3.0\bin\initdb.exe'/>
                                    </Component>
                                    <Component Id='CmpPostgres' Guid='B0000001-0000-0000-0000-000000000002'>
                                        <File Id='FilePostgres' Name='postgres.exe' DiskId='1' KeyPath='yes' Source='C:\Users\carlos\.theseus\postgresql\18.3.0\bin\postgres.exe'/>
