            <!-- MenÃº inicio -->
            <Directory Id='ProgramMenuFolder'>
                <Directory Id='ApplicationProgramsFolder' Name='Equipos Industriales'/>
            </Directory>

            <!-- Escritorio -->
            <Directory Id='DesktopFolder' Name='Desktop'/>
        </Directory>

        <!-- Acceso directo en menÃº inicio -->
        <DirectoryRef Id='ApplicationProgramsFolder'>
            <Component Id='AppShortcutMenu' Guid='C0000001-0000-0000-0000-000000000001'>
                <Shortcut Id='StartMenuShortcut'
                    Name='Equipos Industriales Server'
                    Description='Inicia el servidor de Equipos Industriales'
                    Target='[Bin]server.exe'
                    WorkingDirectory='Bin'/>
                <RemoveFolder Id='CleanUpStartMenu' Directory='ApplicationProgramsFolder' On='uninstall'/>
                <RegistryValue Root='HKCU' Key='Software\EquiposIndustriales\Server' Name='installed' Type='integer' Value='1' KeyPath='yes'/>
            </Component>
        </DirectoryRef>

        <!-- Acceso directo en escritorio -->
        <DirectoryRef Id='DesktopFolder'>
            <Component Id='AppShortcutDesktop' Guid='C0000001-0000-0000-0000-000000000002'>
                <Shortcut Id='DesktopShortcut'
                    Name='Equipos Industriales Server'
                    Description='Inicia el servidor de Equipos Industriales'
                    Target='[Bin]server.exe'
                    WorkingDirectory='Bin'/>
                <RegistryValue Root='HKCU' Key='Software\EquiposIndustriales\Server' Name='desktop' Type='integer' Value='1' KeyPath='yes'/>
            </Component>
        </DirectoryRef>

        <Feature
            Id='Binaries'
            Title='Application'
            Description='Instala el servidor y la base de datos embebida.'
            Level='1'
            ConfigurableDirectory='APPLICATIONFOLDER'
            AllowAdvertise='no'
            Display='expand'
            Absent='disallow'>

            <ComponentRef Id='binary0'/>
            <ComponentRef Id='AppShortcutMenu'/>
            <ComponentRef Id='AppShortcutDesktop'/>
            <ComponentRef Id='CmpInitdb'/>
            <ComponentRef Id='CmpPostgres'/>
            <ComponentRef Id='CmpPgCtl'/>
            <ComponentRef Id='CmpPsql'/>
